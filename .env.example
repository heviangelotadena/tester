# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000

# ─── Supabase ───────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Resend (Email) ────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# The "from" address for outgoing emails (must be verified in Resend)
# Use "onboarding@resend.dev" for testing, or your own domain once verified
FROM_EMAIL=Tester.io <hello@yourdomain.com>

# Reply-to address — where user replies go
REPLY_TO_EMAIL=support@tester.io

# ─── Google Sheets (optional) ──────────────────────────────────────────────
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_NAME=Form Submissions

# Service Account JSON (entire file as a string)
# Get this from Google Cloud Console
GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","...":...}
